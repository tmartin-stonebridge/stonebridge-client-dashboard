# --- Clerk (auth gate — required, app is unusable without it) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Supabase (Phase 2) ---
# Leave these unset and the app runs on seed data automatically.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI drafting (Phase 4) ---
ANTHROPIC_API_KEY=

# --- App URL used in email/text links ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

